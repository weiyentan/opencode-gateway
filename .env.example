# OpenCode Gateway Configuration
#
# Copy to .env and adjust for your environment.
# All values shown are the defaults.

# Executor plugin type (local, awx, etc.)
GATEWAY_EXECUTOR_TYPE=local

# --- AWX Executor Plugin (required when GATEWAY_EXECUTOR_TYPE=awx) ---
GATEWAY_AWX_BASE_URL=https://aap.tanscloud-internal.com
GATEWAY_AWX_TOKEN=
GATEWAY_AWX_CREATE_WORKSPACE_TEMPLATE_ID=216
GATEWAY_AWX_OPENCODE_LIFECYCLE_TEMPLATE_ID=217
GATEWAY_AWX_WORKSPACE_TEARDOWN_TEMPLATE_ID=218
GATEWAY_AWX_POLL_INTERVAL_SECONDS=5
GATEWAY_AWX_TIMEOUT_SECONDS=300

# Server
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Database
GATEWAY_DATABASE_HOST=localhost
GATEWAY_DATABASE_PORT=5432
GATEWAY_DATABASE_NAME=opencode_gateway
GATEWAY_DATABASE_USER=opencode
GATEWAY_DATABASE_PASSWORD=
GATEWAY_DATABASE_MIN_CONNECTIONS=2
GATEWAY_DATABASE_MAX_CONNECTIONS=10
GATEWAY_DATABASE_CONNECTION_TIMEOUT=30

# ==============================================================
# Docker Compose (used by docker-compose.yaml)
# ==============================================================
# These variables configure the bundled PostgreSQL container.
# The gateway service reads GATEWAY_DATABASE_*; the postgres
# service reads POSTGRES_*.  docker-compose.yaml wires them
# together via the defaults shown below.

# PostgreSQL superuser and database name
POSTGRES_USER=opencode
POSTGRES_PASSWORD=opencode
POSTGRES_DB=opencode_gateway

# Pre-flight policy thresholds — used by ObservationBasedPolicy to
# decide whether a runner VM is healthy enough to accept a new job.
# GATEWAY_DISK_THRESHOLD_PERCENT=80.0
# GATEWAY_MEMORY_THRESHOLD_PERCENT=85.0
# GATEWAY_STALENESS_SECONDS=600

# Cleanup policy (see GATEWAY_CLEANUP_* above for retention
# and interval controls — the Docker image uses the same
# pydantic-settings pipeline, so any GATEWAY_* variable can
# be set in the environment block of docker-compose.yaml or
# in this .env file.)
